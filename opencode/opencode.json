{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "plan",
    "permission": {
        "webfetch": "allow"
    },
    "agent": {
        "build": {
            "color": "#ff7480"
        },
        "plan": {
            "color": "#a3d79a"
        }
    },
    "provider": {
        "llamacpp": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "llama.cpp Server",
            "options": {
                "baseURL": "http://localhost:6676/v1"
            },
            "models": {
                "Gemma-4": {
                    "name": "Gemma 4",
                    "limit": {
                        "context": 75000,
                        "output": 16000
                    }
                }
            }
        }
    }
}
